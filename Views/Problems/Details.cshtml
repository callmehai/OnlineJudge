@model OnlineJudge.Models.Problem

@{
    ViewData["Title"] = "Details";
}

<h1>Details Problem</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            Time Limit:
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TimeLimitMs)ms
        </dd>
        <dt class="col-sm-2">
            Memory Limit:
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MemoryLimitMb)mb
        </dd>
    </dl>
</div>
<div>
    <a asp-controller="Submissions" asp-action="Create" asp-route-problemId="@Model.Id" class="btn btn-primary">
        Submit Code
    </a>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
